let routes = {
  "/": "hello",
  "/health": "ok",
  "GET /json": {
    status: 200,
    body: json.stringify({ message: "hello", count: 2 }),
    headers: { "Content-Type": "application/json; charset=utf-8" }
  },
  "GET /header-inject": {
    status: 200,
    body: "safe",
    headers: { "X-Test": "ok\r\nInjected: yes" }
  },
  "POST /submit": "posted"
};

http.serve(0, routes);
